# Server
SERVER_PORT=8080
SERVER_TIMEOUT_READ=3s
SERVER_TIMEOUT_WRITE=5s
SERVER_TIMEOUT_IDLE=5s
SERVER_DEBUG=true

# CORS — comma-separated allowed origins for the frontend. Optional;
# defaults to common localhost dev ports when unset.
# ALLOWED_ORIGINS=http://localhost:3000,https://klyvi.app

# Database (Supabase Postgres; pooler host shown as an example)
DB_HOST=your-project.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.your_project_ref
DB_PASS=replace_me
DB_NAME=postgres
DB_SSLMODE=require
DB_DEBUG=true

# TMDB
TMDB_API_KEY=replace_me
TMDB_BASE_URL=https://api.themoviedb.org/3

# Supabase Auth
SUPABASE_JWKS_URL=https://your_project_ref.supabase.co/auth/v1/.well-known/jwks.json